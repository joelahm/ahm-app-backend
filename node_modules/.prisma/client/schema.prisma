generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  code        String   @id @db.VarChar(32)
  description String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]

  @@map("roles")
}

model User {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  email             String    @unique(map: "uq_users_email") @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  roleCode          String    @map("role_code") @db.VarChar(32)
  firstName         String?   @map("first_name") @db.VarChar(120)
  lastName          String?   @map("last_name") @db.VarChar(120)
  status            String    @default("ACTIVE") @db.VarChar(32)
  isActive          Boolean   @default(true) @map("is_active")
  passwordChangedAt DateTime? @map("password_changed_at")
  lastLoginAt       DateTime? @map("last_login_at")
  createdBy         BigInt?   @map("created_by") @db.UnsignedBigInt
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  role          Role           @relation(fields: [roleCode], references: [code], map: "fk_users_role_code")
  identities    AuthIdentity[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("AuditActor")

  @@index([roleCode], map: "idx_users_role_code")
  @@index([status, isActive], map: "idx_users_status_active")
  @@map("users")
}

model AuthIdentity {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId              BigInt    @map("user_id") @db.UnsignedBigInt
  provider            String    @db.VarChar(64)
  providerUserId      String    @map("provider_user_id") @db.VarChar(255)
  providerEmail       String?   @map("provider_email") @db.VarChar(255)
  providerProfileJson Json?     @map("provider_profile_json")
  linkedAt            DateTime  @default(now()) @map("linked_at")
  lastUsedAt          DateTime? @map("last_used_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_auth_identity_user")

  @@unique([provider, providerUserId], map: "uq_auth_identity_provider_user")
  @@index([userId], map: "idx_auth_identity_user_id")
  @@index([provider], map: "idx_auth_identity_provider")
  @@map("auth_identities")
}

model RefreshToken {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId        BigInt    @map("user_id") @db.UnsignedBigInt
  sessionId     String    @map("session_id") @db.Char(36)
  tokenFamily   String    @map("token_family") @db.Char(36)
  jti           String    @unique(map: "uq_refresh_jti") @db.Char(36)
  tokenHash     String    @unique(map: "uq_refresh_token_hash") @map("token_hash") @db.Char(64)
  expiresAt     DateTime  @map("expires_at")
  isRevoked     Boolean   @default(false) @map("is_revoked")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason") @db.VarChar(128)
  replacedByJti String?   @map("replaced_by_jti") @db.Char(36)
  createdByIp   String?   @map("created_by_ip") @db.VarChar(64)
  userAgent     String?   @map("user_agent") @db.VarChar(255)
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_refresh_user")

  @@index([userId], map: "idx_refresh_user_id")
  @@index([sessionId], map: "idx_refresh_session_id")
  @@index([tokenFamily], map: "idx_refresh_family")
  @@index([expiresAt], map: "idx_refresh_expires_at")
  @@map("refresh_tokens")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  actorUserId  BigInt?  @map("actor_user_id") @db.UnsignedBigInt
  action       String   @db.VarChar(128)
  resourceType String   @map("resource_type") @db.VarChar(64)
  resourceId   String?  @map("resource_id") @db.VarChar(64)
  requestId    String?  @map("request_id") @db.VarChar(64)
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  userAgent    String?  @map("user_agent") @db.VarChar(255)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, map: "fk_audit_actor_user")

  @@index([actorUserId], map: "idx_audit_actor_user_id")
  @@index([action, createdAt], map: "idx_audit_action_created_at")
  @@index([resourceType, resourceId], map: "idx_audit_resource")
  @@map("audit_logs")
}
