generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  code        String    @id @db.VarChar(32)
  description String    @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  users       User[]
  invitations UserInvitation[]

  @@map("roles")
}

model AppSetting {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  key       String   @unique(map: "uq_app_settings_key") @map("setting_key") @db.VarChar(120)
  valueJson Json     @map("value_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model User {
  id                BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  email             String         @unique(map: "uq_users_email") @db.VarChar(255)
  passwordHash      String?        @map("password_hash") @db.VarChar(255)
  roleCode          String         @map("role_code") @db.VarChar(32)
  firstName         String?        @map("first_name") @db.VarChar(120)
  lastName          String?        @map("last_name") @db.VarChar(120)
  avatarUrl         String?        @map("avatar_url") @db.VarChar(512)
  title             String?        @db.VarChar(120)
  phoneNumber       String?        @map("phone_number") @db.VarChar(64)
  country           String?        @db.VarChar(120)
  timezone          String?        @db.VarChar(64)
  dateFormat        String?        @map("date_format") @db.VarChar(32)
  status            String         @default("ACTIVE") @db.VarChar(32)
  isActive          Boolean        @default(true) @map("is_active")
  passwordChangedAt DateTime?      @map("password_changed_at")
  lastLoginAt       DateTime?      @map("last_login_at")
  createdBy         BigInt?        @map("created_by") @db.UnsignedBigInt
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  role              Role           @relation(fields: [roleCode], references: [code], map: "fk_users_role_code")
  identities        AuthIdentity[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]     @relation("AuditActor")
  sentInvitations   UserInvitation[] @relation("InvitedByUser")
  createdClients    Client[]       @relation("ClientCreatedBy")
  assignedClients   Client[]       @relation("ClientAssignedTo")
  clientSuccessManagedProjects ClientProject[] @relation("ClientSuccessManagedProjects")
  accountManagedProjects       ClientProject[] @relation("AccountManagedProjects")
  createdClientProjects        ClientProject[] @relation("ClientProjectCreatedBy")
  createdClientCitations       ClientCitation[] @relation("ClientCitationCreatedBy")
  createdProjectTemplates      ProjectTemplate[] @relation("ProjectTemplateCreatedBy")
  assignedProjectTasks         ProjectTask[]   @relation("ProjectTaskAssignedTo")
  createdProjectTasks          ProjectTask[]   @relation("ProjectTaskCreatedBy")
  taskComments                 TaskComment[]   @relation("TaskCommentCreatedBy")
  projectComments              ProjectComment[] @relation("ProjectCommentCreatedBy")
  externalApiLogs              ExternalApiLog[] @relation("ExternalApiLogRequestedBy")
  manusApiLogs                 ManusApiLog[] @relation("ManusApiLogRequestedBy")
  createdScans                 Scan[]         @relation("ScanCreatedBy")
  triggeredScanRuns            ScanRun[]      @relation("ScanRunTriggeredBy")
  createdGeneratedSchemas     GeneratedSchema[] @relation("GeneratedSchemaCreatedBy")
  createdAiPrompts            AiPrompt[] @relation("AiPromptCreatedBy")
  createdCitationDatabaseEntries CitationDatabaseEntry[] @relation("CitationDatabaseEntryCreatedBy")
  createdKeywordContentLists    KeywordContentList[] @relation("KeywordContentListCreatedBy")
  createdReviewReplyDrafts      ClientReviewReplyDraft[] @relation("ClientReviewReplyDraftCreatedBy")
  updatedReviewReplyDrafts      ClientReviewReplyDraft[] @relation("ClientReviewReplyDraftUpdatedBy")
  createdGbpPostings            ClientGbpPosting[] @relation("ClientGbpPostingCreatedBy")
  assignedGbpPostings           ClientGbpPosting[] @relation("ClientGbpPostingAssignedTo")
  createdGbpPostingComments     ClientGbpPostingComment[] @relation("ClientGbpPostingCommentCreatedBy")

  @@index([roleCode], map: "idx_users_role_code")
  @@index([status, isActive], map: "idx_users_status_active")
  @@map("users")
}

model UserInvitation {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  email      String    @db.VarChar(255)
  roleCode   String    @map("role_code") @db.VarChar(32)
  locationsJson Json?  @map("locations_json")
  tokenHash  String    @unique(map: "uq_user_invitation_token_hash") @map("token_hash") @db.Char(64)
  invitedBy  BigInt?   @map("invited_by") @db.UnsignedBigInt
  status     String    @default("PENDING") @db.VarChar(32)
  expiresAt  DateTime  @map("expires_at")
  sentAt     DateTime? @map("sent_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  role           Role  @relation(fields: [roleCode], references: [code], map: "fk_user_invitation_role")
  invitedByUser  User? @relation("InvitedByUser", fields: [invitedBy], references: [id], onDelete: SetNull, map: "fk_user_invitation_invited_by")

  @@index([email], map: "idx_user_invitation_email")
  @@index([status], map: "idx_user_invitation_status")
  @@index([expiresAt], map: "idx_user_invitation_expires_at")
  @@map("user_invitations")
}

model AuthIdentity {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId              BigInt    @map("user_id") @db.UnsignedBigInt
  provider            String    @db.VarChar(64)
  providerUserId      String    @map("provider_user_id") @db.VarChar(255)
  providerEmail       String?   @map("provider_email") @db.VarChar(255)
  providerProfileJson Json?     @map("provider_profile_json")
  linkedAt            DateTime  @default(now()) @map("linked_at")
  lastUsedAt          DateTime? @map("last_used_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_auth_identity_user")

  @@unique([provider, providerUserId], map: "uq_auth_identity_provider_user")
  @@index([userId], map: "idx_auth_identity_user_id")
  @@index([provider], map: "idx_auth_identity_provider")
  @@map("auth_identities")
}

model RefreshToken {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt    @map("user_id") @db.UnsignedBigInt
  sessionId    String    @map("session_id") @db.Char(36)
  tokenFamily  String    @map("token_family") @db.Char(36)
  jti          String    @unique(map: "uq_refresh_jti") @db.Char(36)
  tokenHash    String    @unique(map: "uq_refresh_token_hash") @map("token_hash") @db.Char(64)
  expiresAt    DateTime  @map("expires_at")
  isRevoked    Boolean   @default(false) @map("is_revoked")
  revokedAt    DateTime? @map("revoked_at")
  revokedReason String?  @map("revoked_reason") @db.VarChar(128)
  replacedByJti String?  @map("replaced_by_jti") @db.Char(36)
  createdByIp   String?  @map("created_by_ip") @db.VarChar(64)
  userAgent     String?  @map("user_agent") @db.VarChar(255)
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_refresh_user")

  @@index([userId], map: "idx_refresh_user_id")
  @@index([sessionId], map: "idx_refresh_session_id")
  @@index([tokenFamily], map: "idx_refresh_family")
  @@index([expiresAt], map: "idx_refresh_expires_at")
  @@map("refresh_tokens")
}

model AuditLog {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  actorUserId  BigInt?   @map("actor_user_id") @db.UnsignedBigInt
  action       String    @db.VarChar(128)
  resourceType String    @map("resource_type") @db.VarChar(64)
  resourceId   String?   @map("resource_id") @db.VarChar(64)
  requestId    String?   @map("request_id") @db.VarChar(64)
  ipAddress    String?   @map("ip_address") @db.VarChar(64)
  userAgent    String?   @map("user_agent") @db.VarChar(255)
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")

  actor        User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, map: "fk_audit_actor_user")

  @@index([actorUserId], map: "idx_audit_actor_user_id")
  @@index([action, createdAt], map: "idx_audit_action_created_at")
  @@index([resourceType, resourceId], map: "idx_audit_resource")
  @@map("audit_logs")
}

model Client {
  id                            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  clientName                    String    @map("client_name") @db.VarChar(180)
  businessName                  String    @map("business_name") @db.VarChar(180)
  niche                         String    @db.VarChar(255)
  personalEmail                 String    @map("personal_email") @db.VarChar(255)
  personalPhone                 String?   @map("personal_phone") @db.VarChar(64)
  practiceEmail                 String    @map("practice_email") @db.VarChar(255)
  businessPhone                 String    @map("business_phone") @db.VarChar(64)
  website                       String?   @db.VarChar(255)
  country                       String    @db.VarChar(120)
  typeOfPractice                String?   @map("type_of_practice") @db.VarChar(180)
  profession                    String?   @db.VarChar(180)
  practiceStructure             String?   @map("practice_structure") @db.VarChar(180)
  gmcRegistrationNumber         String?   @map("gmc_registration_number") @db.VarChar(120)
  topMedicalSpecialties         Json?     @map("top_medical_specialties")
  otherMedicalSpecialties       Json?     @map("other_medical_specialties")
  subSpecialties                Json?     @map("sub_specialties")
  specialInterests              Json?     @map("special_interests")
  topTreatments                 Json?     @map("top_treatments")
  practiceIntroduction          String?   @map("practice_introduction") @db.Text
  uniqueToCompetitors           String?   @map("unique_to_competitors") @db.Text
  credentials                   String?   @db.Text
  majorAccomplishments          String?   @map("major_accomplishments") @db.Text
  highQualityHeadshot           Json?     @map("high_quality_headshot")
  yourCv                        Json?     @map("your_cv")
  practiceLocationInteriorPhoto Json?     @map("practice_location_interior_photo")
  practiceLocationExteriorPhoto Json?     @map("practice_location_exterior_photo")
  otherImages                   Json?     @map("other_images")
  buildingName                  String?   @map("building_name") @db.VarChar(255)
  unitNumber                    String?   @map("unit_number") @db.VarChar(120)
  streetAddress                 String?   @map("street_address") @db.VarChar(255)
  region                        String?   @db.VarChar(180)
  addressLine1                  String?   @map("address_line_1") @db.VarChar(255)
  addressLine2                  String?   @map("address_line_2") @db.VarChar(255)
  cityState                     String?   @map("city_state") @db.VarChar(180)
  postCode                      String?   @map("post_code") @db.VarChar(64)
  visibleArea                   String?   @map("visible_area") @db.VarChar(255)
  nearbyAreasServed             String?   @map("nearby_areas_served") @db.VarChar(500)
  practiceHours                 Json?     @map("practice_hours")
  gbpLink                       String?   @map("gbp_link") @db.VarChar(255)
  facebook                      String?   @db.VarChar(255)
  instagram                     String?   @db.VarChar(255)
  linkedin                      String?   @db.VarChar(255)
  websiteLoginLink              String?   @map("website_login_link") @db.VarChar(255)
  websiteUsername               String?   @map("website_username") @db.VarChar(255)
  websitePassword               String?   @map("website_password") @db.VarChar(255)
  googleAnalytics               String?   @map("google_analytics") @db.VarChar(255)
  googleSearchConsole           String?   @map("google_search_console") @db.VarChar(255)
  colorGuide                    Json?     @map("color_guide")
  logo                          Json?
  treatmentAndServices          Json?     @map("treatment_and_services")
  conditionsTreated             Json?     @map("conditions_treated")
  status                        String    @default("ACTIVE") @db.VarChar(32)
  assignedTo                    BigInt?   @map("assigned_to") @db.UnsignedBigInt
  createdBy                     BigInt?   @map("created_by") @db.UnsignedBigInt
  createdAt                     DateTime  @default(now()) @map("created_at")
  updatedAt                     DateTime  @updatedAt @map("updated_at")

  creator                       User?     @relation("ClientCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, map: "fk_clients_created_by")
  assignedUser                  User?     @relation("ClientAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull, map: "fk_clients_assigned_to")
  projects                      ClientProject[]
  citations                     ClientCitation[]
  externalApiLogs               ExternalApiLog[]
  manusApiLogs                  ManusApiLog[]
  keywordContentLists           KeywordContentList[]
  gbpProfile                    ClientGbpProfile?
  scans                         Scan[]
  generatedSchemas              GeneratedSchema[]
  aiPrompts                     AiPrompt[]
  reviewReplyDrafts             ClientReviewReplyDraft[]
  gbpPostings                   ClientGbpPosting[]

  @@index([businessName], map: "idx_clients_business_name")
  @@index([practiceEmail], map: "idx_clients_practice_email")
  @@index([status], map: "idx_clients_status")
  @@index([assignedTo], map: "idx_clients_assigned_to")
  @@index([createdBy], map: "idx_clients_created_by")
  @@map("clients")
}

model ClientProject {
  id                     BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  clientId               BigInt   @map("client_id") @db.UnsignedBigInt
  project                String   @db.VarChar(180)
  clientSuccessManagerId BigInt?  @map("client_success_manager_id") @db.UnsignedBigInt
  accountManagerId       BigInt?  @map("account_manager_id") @db.UnsignedBigInt
  startDate              DateTime? @map("start_date")
  dueDate                DateTime? @map("due_date")
  phase                  String   @db.VarChar(120)
  progress               String   @db.VarChar(120)
  createdBy              BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade, map: "fk_client_projects_client")
  clientSuccessManager   User?    @relation("ClientSuccessManagedProjects", fields: [clientSuccessManagerId], references: [id], onDelete: SetNull, map: "fk_client_projects_client_success_manager")
  accountManager         User?    @relation("AccountManagedProjects", fields: [accountManagerId], references: [id], onDelete: SetNull, map: "fk_client_projects_account_manager")
  creator                User?    @relation("ClientProjectCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, map: "fk_client_projects_created_by")
  tasks                  ProjectTask[]
  comments               ProjectComment[]
  externalApiLogs        ExternalApiLog[]

  @@index([clientId], map: "idx_client_projects_client_id")
  @@index([clientSuccessManagerId], map: "idx_client_projects_client_success_manager_id")
  @@index([accountManagerId], map: "idx_client_projects_account_manager_id")
  @@index([createdBy], map: "idx_client_projects_created_by")
  @@map("client_projects")
}

model ProjectTemplate {
  id          String   @id @db.VarChar(64)
  projectName String   @map("project_name") @db.VarChar(180)
  description String   @db.LongText
  status      String   @db.VarChar(64)
  tasks       Json
  createdBy   BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator     User?    @relation("ProjectTemplateCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, map: "fk_project_templates_created_by")

  @@index([updatedAt], map: "idx_project_templates_updated_at")
  @@index([createdBy], map: "idx_project_templates_created_by")
  @@map("project_templates")
}

model ClientCitation {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  clientId      BigInt   @map("client_id") @db.UnsignedBigInt
  citationDatabaseEntryId String? @map("citation_database_entry_id") @db.VarChar(64)
  directoryName String   @map("directory_name") @db.VarChar(180)
  status        String   @default("NOT_SYNCED") @db.VarChar(64)
  profileUrl    String?  @map("profile_url") @db.VarChar(500)
  username      String?  @db.VarChar(255)
  password      String?  @db.VarChar(255)
  notes         String?  @db.Text
  verificationStatus Json? @map("verification_status")
  createdBy     BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade, map: "fk_client_citations_client")
  citationDatabaseEntry CitationDatabaseEntry? @relation(fields: [citationDatabaseEntryId], references: [id], onDelete: SetNull, map: "fk_client_citations_citation_database_entry")
  creator       User?    @relation("ClientCitationCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, map: "fk_client_citations_created_by")

  @@unique([clientId, directoryName], map: "uq_client_citations_client_directory")
  @@index([clientId], map: "idx_client_citations_client_id")
  @@index([citationDatabaseEntryId], map: "idx_client_citations_citation_database_entry_id")
  @@index([status], map: "idx_client_citations_status")
  @@index([createdBy], map: "idx_client_citations_created_by")
  @@map("client_citations")
}

model ProjectTask {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  projectId   BigInt    @map("project_id") @db.UnsignedBigInt
  parentTaskId BigInt?  @map("parent_task_id") @db.UnsignedBigInt
  task        String    @db.VarChar(180)
  projectType String?   @map("project_type") @db.VarChar(120)
  description String?   @db.Text
  status      String    @default("TODO") @db.VarChar(64)
  priority    String    @default("MEDIUM") @db.VarChar(64)
  startDate   DateTime? @map("start_date")
  dueDate     DateTime? @map("due_date")
  assignedTo  BigInt?   @map("assigned_to") @db.UnsignedBigInt
  createdBy   BigInt?   @map("created_by") @db.UnsignedBigInt
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "fk_project_tasks_project")
  parentTask  ProjectTask?  @relation("ProjectTaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull, map: "fk_project_tasks_parent_task")
  subtasks    ProjectTask[] @relation("ProjectTaskHierarchy")
  assignedUser User?        @relation("ProjectTaskAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull, map: "fk_project_tasks_assigned_to")
  creator      User?        @relation("ProjectTaskCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull, map: "fk_project_tasks_created_by")
  comments     TaskComment[]

  @@index([projectId], map: "idx_project_tasks_project_id")
  @@index([parentTaskId], map: "idx_project_tasks_parent_task_id")
  @@index([assignedTo], map: "idx_project_tasks_assigned_to")
  @@index([createdBy], map: "idx_project_tasks_created_by")
  @@map("project_tasks")
}

model TaskComment {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  taskId    BigInt   @map("task_id") @db.UnsignedBigInt
  comment   String   @db.Text
  createdBy BigInt   @map("created_by") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task      ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade, map: "fk_task_comments_task")
  creator   User        @relation("TaskCommentCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade, map: "fk_task_comments_created_by")

  @@index([taskId], map: "idx_task_comments_task_id")
  @@index([createdBy], map: "idx_task_comments_created_by")
  @@map("task_comments")
}

model ProjectComment {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  projectId BigInt   @map("project_id") @db.UnsignedBigInt
  comment   String   @db.Text
  createdBy BigInt   @map("created_by") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "fk_project_comments_project")
  creator   User          @relation("ProjectCommentCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade, map: "fk_project_comments_created_by")

  @@index([projectId], map: "idx_project_comments_project_id")
  @@index([createdBy], map: "idx_project_comments_created_by")
  @@map("project_comments")
}

model ExternalApiLog {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  provider           String    @db.VarChar(64)
  operation          String    @db.VarChar(128)
  cacheNamespace     String    @map("cache_namespace") @db.VarChar(128)
  requestHash        String    @map("request_hash") @db.Char(64)
  clientId           BigInt?   @map("client_id") @db.UnsignedBigInt
  projectId          BigInt?   @map("project_id") @db.UnsignedBigInt
  requestedBy        BigInt?   @map("requested_by") @db.UnsignedBigInt
  externalTaskId     String?   @map("external_task_id") @db.VarChar(128)
  endpoint           String    @db.VarChar(255)
  requestMethod      String    @map("request_method") @db.VarChar(16)
  requestPayload     Json      @map("request_payload")
  responseStatusCode Int?      @map("response_status_code")
  responsePayload    Json?     @map("response_payload")
  isSuccess          Boolean   @default(false) @map("is_success")
  errorMessage       String?   @map("error_message") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client             Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull, map: "fk_external_api_logs_client")
  project            ClientProject? @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "fk_external_api_logs_project")
  requester          User?     @relation("ExternalApiLogRequestedBy", fields: [requestedBy], references: [id], onDelete: SetNull, map: "fk_external_api_logs_requested_by")

  @@index([provider, operation], map: "idx_external_api_logs_provider_operation")
  @@index([cacheNamespace, requestHash, createdAt], map: "idx_external_api_logs_cache_lookup")
  @@index([clientId], map: "idx_external_api_logs_client_id")
  @@index([projectId], map: "idx_external_api_logs_project_id")
  @@index([requestedBy], map: "idx_external_api_logs_requested_by")
  @@index([createdAt], map: "idx_external_api_logs_created_at")
  @@map("external_api_logs")
}

model ManusApiLog {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  operation          String    @db.VarChar(128)
  clientId           BigInt?   @map("client_id") @db.UnsignedBigInt
  requestedBy        BigInt?   @map("requested_by") @db.UnsignedBigInt
  endpoint           String    @db.VarChar(255)
  requestMethod      String    @map("request_method") @db.VarChar(16)
  requestPayload     Json      @map("request_payload")
  responseStatusCode Int?      @map("response_status_code")
  responsePayload    Json?     @map("response_payload")
  isSuccess          Boolean   @default(false) @map("is_success")
  externalTaskId     String?   @map("external_task_id") @db.VarChar(128)
  errorMessage       String?   @map("error_message") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client             Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull, map: "fk_manus_api_logs_client")
  requester          User?     @relation("ManusApiLogRequestedBy", fields: [requestedBy], references: [id], onDelete: SetNull, map: "fk_manus_api_logs_requested_by")

  @@index([operation], map: "idx_manus_api_logs_operation")
  @@index([clientId], map: "idx_manus_api_logs_client_id")
  @@index([requestedBy], map: "idx_manus_api_logs_requested_by")
  @@index([createdAt], map: "idx_manus_api_logs_created_at")
  @@map("manus_api_logs")
